{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "boilerplate",
	"version": "0.5.0",
	"identifier": "com.onivoid.boilerplate",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
		    {
		        "title": "boilerplate",
		        "width": 1000,
		        "height": 700,
		        "resizable": true,
		        "fullscreen": false,
		        "decorations": false,
		        "transparent": true,
		        "shadow": true
		    }
		],		"security": {
			"csp": "default-src 'self'; img-src 'self' asset: https://*; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://localhost:1420"
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"windows": {
			"nsis": {
				"installerIcon": "icons/icon.ico",
				"installMode": "perMachine"
			}
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZENjk5Q0E4MzcxQUMyODcKUldTSHdobzNxSnhwYmUzUUdUeG5DZ1AvOG5tbVZEbmpQTHBqakFXWitxVDJCN014RDcybjlWY1IK",
			"endpoints": [
				"https://github.com/Onivoid/Tauri-React-Boilerplate/releases/latest/download/latest.json"
			],
			"windows": {
				"installMode": "passive"
			}
		}
	}
}
